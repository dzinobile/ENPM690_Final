<!--
  TARS Model

  Structure
  ---------
  4 main slabs with (left, middle x2, right)
  2 upper arms (left, right)
  2 lower arms (lower x2)
  
  Actuators (10 total, in order):
    0 ud_lm up-down left-middle
    1 ud_mm up-down middle-middle
    2 ud_rm up-down right-middle
    3 r_lm rotate left-middle
    4 r_mm rotate middle-middle
    5 r_rm rotate right-middle
    6 r_lu rotate left-upper
    7 r_ru rotate right-upper
    8 r_ll rotate left-lower
    9 r_rl rotate right-lower

  Forward direction is +x.  
-->
<mujoco model="tars">

  <compiler angle="degree"/>

  <asset>
    <texture name="body" type="cube" builtin="flat" mark="cross" width="128" height="128" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" markrgb="1 1 1"/>
    <material name="body" texture="body" texuniform="true" rgba="0.8 0.6 .4 1"/>
  </asset>

  <option timestep="0.001" integrator="RK4" gravity="0 0 -9.81"/>

  <default>
    <joint limited="true" damping="30" armature="0.05" stiffness="0" actuatorfrcrange="-400 400"/>
    <!-- contype=0 conaffinity=0: structural geoms (torso, leg capsules) do not
         participate in any collision.  Feet override this to contype=1 so they
         collide with the floor (conaffinity=1) but not with each other. -->
    <geom condim="3" friction="1.2 0.005 0.0001" density="100"
          contype="0" conaffinity="0"/>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="120"/>
    <!-- humanoid body defaults (applied via childclass="body" on human_torso) -->
    <default class="body">
      <geom type="capsule" condim="1" friction=".7" solimp=".9 .99 .003" solref=".015 1"
            material="body" group="1" contype="1" conaffinity="1"/>
      <default class="thigh">
        <geom size=".06"/>
      </default>
      <default class="shin">
        <geom fromto="0 0 0 0 0 -.3" size=".049"/>
      </default>
      <default class="foot">
        <geom size=".027"/>
        <default class="foot1">
          <geom fromto="-.07 -.01 0 .14 -.03 0"/>
        </default>
        <default class="foot2">
          <geom fromto="-.07 .01 0 .14  .03 0"/>
        </default>
      </default>
      <default class="arm_upper">
        <geom size=".04"/>
      </default>
      <default class="arm_lower">
        <geom size=".031"/>
      </default>
      <default class="hand">
        <geom type="sphere" size=".04"/>
      </default>
    </default>
  </default>

  <worldbody>
    <light name="sun" pos="0 0 6" dir="0 0 -1" diffuse="1 1 1" specular="0.3 0.3 0.3"/>
    <geom name="floor" type="plane" size="50 50 0.1"
          rgba="0.75 0.85 0.75 1" contype="1" conaffinity="1"/>

    <!-- ── Middle Right ──────────────────────────────────────────────────────── -->
    <body name="middle_right" pos="0 0 0.8" euler="45 0 0">
      <freejoint name="root"/>
      <!-- Slot shape: central box + two half-cylinders capping the ±x ends -->
      <geom name="middle_geom_box" type="box" size="0.125 0.125 0.875"
             rgba="0.35 0.45 0.75 1" 
             contype="1" conaffinity="0"/>
      <geom name="middle_geom_cap_pos" type="cylinder" pos="0 0 0.875"
            size="0.125 0.125" euler="0 90 0"
             rgba="0.35 0.45 0.75 1"
            contype="1" conaffinity="0"/>
      <geom name="middle_geom_cap_neg" type="cylinder" pos="0 0 -0.875"
            size="0.125 0.125" euler="0 90 0"
             rgba="0.35 0.45 0.75 1"
            contype="1" conaffinity="0"/>

      <!-- ── Middle Left ──────────────────────────────────────────── -->
      <!-- pos: 0.25 m to the left (-x) of middle_right              -->
      <!-- joint pos: +0.25 x in middle_left's frame = middle_right's center -->
      <body name="middle_left" pos="0.25 0 0" euler="0 0 0" >
        <joint name="ud_mm" type="slide" axis="0 0 1" range="-50 50"/>
        <joint name="r_mm" type="hinge" axis="1 0 0" pos="0 0 0" range="-355 355"/>
        <geom name="ml_geom_box" type="box" size="0.125 0.125 0.875"
               rgba="0.55 0.65 0.45 1"
               contype="1" conaffinity="0"/>
        <geom name="ml_geom_cap_pos" type="cylinder" pos="0 0 0.875"
              size="0.125 0.125" euler="0 90 0"
              rgba="0.55 0.65 0.45 1"
              contype="1" conaffinity="0"/>
        <geom name="ml_geom_cap_neg" type="cylinder" pos="0 0 -0.875"
              size="0.125 0.125" euler="0 90 0"
              rgba="0.55 0.65 0.45 1"
              contype="1" conaffinity="0"/>
      </body>

      <!-- ── Left ──────────────────────────────────────────── -->
      <!-- pos: 0.5 m to the left (-x) of middle_right              -->
      <!-- joint pos: +0.5 x in middle_left's frame = middle_right's center -->
      <body name="left" pos="0.5 0 0" euler="90 0 0" >
        <joint name="ud_lm" type="slide" axis="0 0 1" range="-50 50"/>
        <joint name="r_lm" type="hinge" axis="1 0 0" pos="0 0 0" range="-355 355"/>
        <geom name="l_geom_box" type="box" size="0.125 0.125 0.875"
               rgba="0.55 0.65 0.45 1"
               contype="1" conaffinity="0"/>
        <geom name="l_geom_cap_pos" type="cylinder" pos="0 0 0.875"
              size="0.125 0.125" euler="0 90 0"
              rgba="0.55 0.65 0.45 1"
              contype="1" conaffinity="0"/>
        <geom name="l_geom_cap_neg" type="cylinder" pos="0 0 -0.875"
              size="0.125 0.125" euler="0 90 0"
               rgba="0.55 0.65 0.45 1"
              contype="1" conaffinity="0"/>

        <!-- ── Left Arm Upper ──────────────────────────────────────────── -->
        <body name="left_arm_upper" pos="0.0625 0.0625 -0.5" euler="0 0 0" >
          <joint name="r_lu" type="hinge" axis="1 0 0" pos="0 0 0.5" range="-5 355" />
          <geom name="lu_geom_box" type="box" size="0.0625 0.0625 0.5"
              rgba="1 0 0 1"
              contype="1" conaffinity="0"/>
          <!-- ── Left Arm Lower ──────────────────────────────────────────── -->
          <body name="left_arm_lower" pos="-0.03125 -0.03125 -0.5" euler="0 0 0" >
            <joint name="r_ll" type="hinge" axis="1 0 0" pos="0 0 0" range="-5 355"/>
            <geom name="ll_geom_box" type="box" size="0.03125 0.03125 0.25"
                pos="0 0 0.25" rgba="0 1 0 1"
                contype="1" conaffinity="0"/>
          </body>
          
        </body>
        


      </body>

      <!-- ── Right ──────────────────────────────────────────── -->
      <!-- pos: 0.25 m to the right (-x) of middle_right              -->
      <!-- joint pos: -0.25 x in middle_left's frame = middle_right's center -->
      <body name="right" pos="-0.25 0 0" euler="90 0 0" >
        <joint name="ud_rm" type="slide" axis="0 0 1" range="-50 50"/>
        <joint name="r_rm" type="hinge" axis="1 0 0" pos="0 0 0" range="-355 355"/>
        <geom name="r_geom_box" type="box" size="0.125 0.125 0.875"
               rgba="0.55 0.65 0.45 1"
               contype="1" conaffinity="0"/>
        <geom name="r_geom_cap_pos" type="cylinder" pos="0 0 0.875"
              size="0.125 0.125" euler="0 90 0"
               rgba="0.55 0.65 0.45 1"
              contype="1" conaffinity="0"/>
        <geom name="r_geom_cap_neg" type="cylinder" pos="0 0 -0.875"
              size="0.125 0.125" euler="0 90 0"
              rgba="0.55 0.65 0.45 1"
              contype="1" conaffinity="0"/>



        <!-- ── Right Arm Upper ──────────────────────────────────────────── -->
        <body name="right_arm_upper" pos="-0.0625 0.0625 -0.5" euler="0 0 0" >
          <joint name="r_ru" type="hinge" axis="1 0 0" pos="0 0 0.5" range="-5 355"/>
          <geom name="ru_geom_box" type="box" size="0.0625 0.0625 0.5"
              rgba="1 0 0 1"
              contype="1" conaffinity="0"/>

          <!-- ── Right Arm Lower ──────────────────────────────────────────── -->
          <body name="right_arm_lower" pos="0.03125 -0.03125 -0.5" euler="0 0 0" >
            <joint name="r_rl" type="hinge" axis="1 0 0" pos="0 0 0" range="-5 355" />
            <geom name="rl_geom_box" type="box" size="0.03125 0.03125 0.25"
                pos="0 0 0.25" rgba="0 1 0 1"
                contype="1" conaffinity="0"/>
          </body>
        </body>
      </body>
    </body>

    <body name="human_torso" pos="2 0 1.282" childclass="body">
      <freejoint name="human_root"/>
      <geom name="human_torso" fromto="0 -.07 0 0 .07 0" size=".07"/>
      <geom name="waist_upper" fromto="-.01 -.06 -.12 -.01 .06 -.12" size=".06"/>
      <body name="head" pos="0 0 .19">
        <geom name="head" type="sphere" size=".09"/>
      </body>
      <body name="waist_lower" pos="-.01 0 -.26">
        <geom name="waist_lower" fromto="0 -.06 0 0 .06 0" size=".06"/>
        <body name="pelvis" pos="0 0 -.165">
          <geom name="butt" fromto="-.02 -.07 0 -.02 .07 0" size=".09"/>
          <body name="thigh_right" pos="0 -.1 -.04">
            <geom name="thigh_right" fromto="0 0 0 0 .01 -.34" class="thigh"/>
            <body name="shin_right" pos="0 .01 -.4">
              <geom name="shin_right" class="shin"/>
              <body name="foot_right" pos="0 0 -.39">
                <geom name="foot1_right" class="foot1"/>
                <geom name="foot2_right" class="foot2"/>
              </body>
            </body>
          </body>
          <body name="thigh_left" pos="0 .1 -.04">
            <geom name="thigh_left" fromto="0 0 0 0 -.01 -.34" class="thigh"/>
            <body name="shin_left" pos="0 -.01 -.4">
              <geom name="shin_left" fromto="0 0 0 0 0 -.3" class="shin"/>
              <body name="foot_left" pos="0 0 -.39">
                <geom name="foot1_left" class="foot1"/>
                <geom name="foot2_left" class="foot2"/>
              </body>
            </body>
          </body>
        </body>
      </body>
      <body name="upper_arm_right" pos="0 -.17 .06">
        <geom name="upper_arm_right" fromto="0 0 0 0 0 -.28" class="arm_upper"/>
        <body name="lower_arm_right" pos="0 0 -.28">
          <geom name="lower_arm_right" fromto="0 0 0 0 0 -.25" class="arm_lower"/>
          <body name="hand_right" pos="0 0 -.25">
            <geom name="hand_right" zaxis="0 0 -1" class="hand"/>
          </body>
        </body>
      </body>
      <body name="upper_arm_left" pos="0 .17 .06">
        <geom name="upper_arm_left" fromto="0 0 0 0 0 -.28" class="arm_upper"/>
        <body name="lower_arm_left" pos="0 0 -.28">
          <geom name="lower_arm_left" fromto="0 0 0 0 0 -.25" class="arm_lower"/>
          <body name="hand_left" pos="0 0 -.25">
            <geom name="hand_left" zaxis="0 0 -1" class="hand"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="waist_lower" body2="thigh_right"/>
    <exclude body1="waist_lower" body2="thigh_left"/>
  </contact>

  <keyframe>
    <key name="init" qpos="0 0 0.8 0.924 0.383 0 0 0 0 0 0 2.8 1.75 0 0 2.8 1.75 -0.3 -0.8 0.7 0.707 0 -0.707 0"/>
  </keyframe>


  <actuator>
    <position name="ud_lm_pos" joint="ud_lm" kp="0.5"  ctrlrange="-50 50"/>
    <position name="ud_mm_pos" joint="ud_mm" kp="0.5"  ctrlrange="-50 50"/>
    <position name="ud_rm_pos" joint="ud_rm" kp="0.5"  ctrlrange="-50 50"/>
    <position name="r_lm_pos" joint="r_lm" kp="0.5"  ctrlrange="-355 355"/>
    <position name="r_mm_pos" joint="r_mm" kp="0.5"  ctrlrange="-355 355"/>
    <position name="r_rm_pos" joint="r_rm" kp="0.5" ctrlrange="-355 355"/>
    <position name="r_lu_pos" joint="r_lu" kp="0.5"  ctrlrange="-5 355"/>
    <position name="r_ru_pos" joint="r_ru" kp="0.5"  ctrlrange="-5 355"/>
    <position name="r_ll_pos" joint="r_ll" kp="0.5"  ctrlrange="-5 355"/>
    <position name="r_rl_pos" joint="r_rl" kp="0.5"  ctrlrange="-5 355"/>
  </actuator>



</mujoco>
