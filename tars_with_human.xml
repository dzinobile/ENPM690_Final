<mujoco>
    <compiler meshdir="binary_meshes" angle="degree" />

    <option timestep="0.001" integrator="RK4" gravity="0 0 -9.81"/>

    <default>
        <joint limited="true" damping="30" armature="0.05" stiffness="0" actuatorfrcrange="-400 400"/>
        <!-- contype=0 conaffinity=0: structural geoms (torso, leg capsules) do not
         participate in any collision.  Feet override this to contype=1 so they
         collide with the floor (conaffinity=1) but not with each other. -->
        <geom condim="3" friction="1.2 0.005 0.0001" density="100" contype="0" conaffinity="0"/>
        <motor ctrllimited="true" ctrlrange="-1 1" gear="120"/>
        <default class="body">
            <geom type="capsule" condim="1" friction=".7" solimp=".9 .99 .003" solref=".015 1"
            material="body" group="1" contype="2" conaffinity="3"/>
            <default class="thigh">
                <geom size=".06"/>
            </default>
            <default class="shin">
                <geom fromto="0 0 0 0 0 -.3" size=".049"/>
            </default>
            <default class="foot">
                <geom size=".027"/>
                <default class="foot1">
                    <geom fromto="-.07 -.01 0 .14 -.03 0"/>
                </default>
                <default class="foot2">
                    <geom fromto="-.07 .01 0 .14  .03 0"/>
                </default>
            </default>
            <default class="arm_upper">
                <geom size=".04"/>
            </default>
            <default class="arm_lower">
                <geom size=".031"/>
            </default>
            <default class="hand">
                <geom type="sphere" size=".04"/>
            </default>
        </default>
    </default>

    <asset>
    <!--this scale makes it so that the robot is 1 meter in height, assuming mujoco base units are in meters-->
        <mesh name="base" file="TARS2_base_link_1.STL"  scale="2 2 2"/>
        <mesh name="middle_left" file="TARS2_middleslab_3.STL" scale="2 2 2"/>
        <mesh name="left" file="TARS2_leftslab_1.STL" scale="2 2 2"/>
        <mesh name="left_upper_arm" file="TARS2_leftarm1_1.STL"  scale="2 2 2"/>
        <mesh name="left_lower_arm" file="TARS2_leftarm2_1.STL" scale="2 2 2"/>
        <mesh name="middle_right" file="TARS2_middleslab_2.STL" scale="2 2 2"/>
        <mesh name="right" file="TARS2_rightslab_1.STL" scale="2 2 2"/>
        <mesh name="right_upper_arm" file="TARS2_rightarm1_1.STL" scale="2 2 2"/>
        <mesh name="right_lower_arm" file="TARS2_leftarm2_2.STL" scale="2 2 2"/>
        <texture name="body" type="cube" builtin="flat" mark="cross" width="128" height="128" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" markrgb="1 1 1"/>
        <material name="body" texture="body" texuniform="true" rgba="0.8 0.6 .4 1"/>
    </asset>

    <worldbody>
        <light name="sun" pos="0 0 6" dir="0 0 -1" diffuse="1 1 1" specular="0.3 0.3 0.3"/>
        <geom name="floor" type="plane" size="50 50 0.1" rgba="0.75 0.85 0.75 1" friction="1.0 0.005 0.0001" contype="1" conaffinity="3" />
        <!--BASE-->
        <body name="base_link" euler="90 0 0">
            <joint type="free" />
            <geom type="mesh" mesh="base" rgba="0.35 0.45 0.75 1" contype="1" conaffinity="0" />
            <!--LEFT CHAIN-->
            <!--LEFT BASE LINK-->
            <body name="left_base_link">
                <joint name="r_lm" type="hinge" axis="1 0 0" pos="0 1 0.15" range="-355 355" damping="100" />
                <joint name="ud_lm" type="slide" axis="0 1 0" range="-0.2 0.2" damping="100" actuatorfrcrange="-400 400"/>
                <geom type="mesh" mesh="middle_left" rgba="0.55 0.65 0.45 1" contype="1" conaffinity="0" />
                <!--LEFT LINK-->
                <body name="left_link">
                    <joint name="r_l" type="hinge" axis="1 0 0" pos="0 1 0.15" range="-355 355" damping="100" />
                    <joint name="ud_l" type="slide" axis="0 1 0" range="-0.2 0.2" damping="100" actuatorfrcrange="-400 400"/>
                    <geom type="mesh" mesh="left" rgba="0.5 0.5 0.5 1" margin="0.0003" gap="0.0001" solref="0.01 1" solimp="0.9 0.95 0.001" contype="1" conaffinity="0" />
                    <!--LEFT UPPER ARM-->
                    <body name="left_upper_arm">
                        <joint name="r_lu" type="hinge" axis="1 0 0" pos="0 1 0.2" range="0 270" damping="100" />
                        <geom name="left_upper_arm_geom" type="mesh" mesh="left_upper_arm" rgba="0.5 0 0.5 1" margin="0.0003" gap="0.0001" solref="0.01 1" solimp="0.9 0.95 0.001" contype="1" conaffinity="0" />
                        <!--LEFT LOWER ARM-->
                        <body name="left_lower_arm">
                            <joint name="r_ll" type="hinge" axis="1 0 0" pos="0 2 0.15" range="0 355" damping="100" />
                            <geom name="left_lower_arm_geom" type="mesh" mesh="left_lower_arm" rgba="0 0.5 0.5 1" margin="0.0003" gap="0.0001" solref="0.01 1" solimp="0.9 0.95 0.001" contype="1" conaffinity="0" />
                        </body>
                    </body>
                </body>
            </body>
            <!--RIGHT CHAIN-->
            <!--RIGHT BASE LINK-->
            <body name="right_base_link">
                <joint name="r_rm" type="hinge" axis="1 0 0" pos="0 1 0.15" range="-355 355" damping="100" />
                <joint name="ud_rm" type="slide" axis="0 1 0" range="-0.2 0.2" damping="100" actuatorfrcrange="-400 400"/>
                <geom type="mesh" mesh="middle_right" rgba="0.55 0.65 0.45 1" contype="1" conaffinity="0" />
                <!--RIGHT LINK-->
                <body name="right_link">
                    <joint name="r_r" type="hinge" axis="1 0 0" pos="0 1 0.15" range="-355 355" damping="100" />
                    <joint name="ud_r" type="slide" axis="0 1 0" range="-0.2 0.2" damping="100" actuatorfrcrange="-400 400"/>
                    <geom type="mesh" mesh="right" rgba="0.5 0.5 0.5 1" margin="0.0003" gap="0.0001" solref="0.01 1" solimp="0.9 0.95 0.001" contype="1" conaffinity="0" />
                    <!--RIGHT UPPER ARM-->
                    <body name="right_upper_arm">
                        <joint name="r_ru" type="hinge" axis="1 0 0" pos="0 1 0.2" range="0 270" damping="100" />
                        <geom name="right_upper_arm_geom" type="mesh" mesh="right_upper_arm" rgba="0.5 0 0.5 1" margin="0.0003" gap="0.0001" solref="0.01 1" solimp="0.9 0.95 0.001" contype="1" conaffinity="0" />
                        <!--RIGHT LOWER ARM-->
                        <body name="right_lower_arm">
                            <joint name="r_rl" type="hinge" axis="1 0 0" pos="0 2 0.15" range="0 355" damping="100" />
                            <geom name="right_lower_arm_geom" type="mesh" mesh="right_lower_arm" rgba="0 0.5 0.5 1" margin="0.0003" gap="0.0001" solref="0.01 1" solimp="0.9 0.95 0.001" contype="1" conaffinity="0" />
                        </body>
                    </body>
                </body>
            </body>
        </body>
        <body name="human_torso" pos="2 0 1.282" childclass="body">
        <freejoint name="human_root"/>
        <geom name="human_torso" fromto="0 -.07 0 0 .07 0" size=".07"/>
        <geom name="waist_upper" fromto="-.01 -.06 -.12 -.01 .06 -.12" size=".06"/>
        <body name="head" pos="0 0 .19">
            <geom name="head" type="sphere" size=".09"/>
        </body>
        <body name="waist_lower" pos="-.01 0 -.26">
            <geom name="waist_lower" fromto="0 -.06 0 0 .06 0" size=".06"/>
            <body name="pelvis" pos="0 0 -.165">
            <geom name="butt" fromto="-.02 -.07 0 -.02 .07 0" size=".09"/>
            <body name="thigh_right" pos="0 -.1 -.04">
                <geom name="thigh_right" fromto="0 0 0 0 .01 -.34" class="thigh"/>
                <body name="shin_right" pos="0 .01 -.4">
                <geom name="shin_right" class="shin"/>
                <body name="foot_right" pos="0 0 -.39">
                    <geom name="foot1_right" class="foot1"/>
                    <geom name="foot2_right" class="foot2"/>
                </body>
                </body>
            </body>
            <body name="thigh_left" pos="0 .1 -.04">
                <geom name="thigh_left" fromto="0 0 0 0 -.01 -.34" class="thigh"/>
                <body name="shin_left" pos="0 -.01 -.4">
                <geom name="shin_left" fromto="0 0 0 0 0 -.3" class="shin"/>
                <body name="foot_left" pos="0 0 -.39">
                    <geom name="foot1_left" class="foot1"/>
                    <geom name="foot2_left" class="foot2"/>
                </body>
                </body>
            </body>
            </body>
        </body>
        <body name="upper_arm_right" pos="0 -.17 .06">
            <geom name="upper_arm_right" fromto="0 0 0 0 0 -.28" class="arm_upper"/>
            <body name="lower_arm_right" pos="0 0 -.28">
            <geom name="lower_arm_right" fromto="0 0 0 0 0 -.25" class="arm_lower"/>
            <body name="hand_right" pos="0 0 -.25">
                <geom name="hand_right" zaxis="0 0 -1" class="hand"/>
            </body>
            </body>
        </body>
        <body name="upper_arm_left" pos="0 .17 .06">
            <geom name="upper_arm_left" fromto="0 0 0 0 0 -.28" class="arm_upper"/>
            <body name="lower_arm_left" pos="0 0 -.28">
            <geom name="lower_arm_left" fromto="0 0 0 0 0 -.25" class="arm_lower"/>
            <body name="hand_left" pos="0 0 -.25">
                <geom name="hand_left" zaxis="0 0 -1" class="hand"/>
            </body>
            </body>
        </body>
        </body>
    </worldbody>

    <contact>
        <exclude body1="waist_lower" body2="thigh_right"/>
        <exclude body1="waist_lower" body2="thigh_left"/>
    </contact>

    <actuator>
        <position name="r_lm_pos" joint="r_lm" kp="2" ctrlrange="-355 355"/>
        <position name="ud_lm_pos" joint="ud_lm" kp="2" ctrlrange="-40 40"/>

        <position name="r_l_pos" joint="r_l" kp="2" ctrlrange="-355 355"/>
        <position name="ud_l_pos" joint="ud_l" kp="2" ctrlrange="-40 40"/>

        <position name="r_lu_pos" joint="r_lu" kp="2" ctrlrange="0 355"/>
        <position name="r_ll_pos" joint="r_ll" kp="2" ctrlrange="0 355"/>

        <position name="r_rm_pos" joint="r_rm" kp="2" ctrlrange="-355 355"/>
        <position name="ud_rm_pos" joint="ud_rm" kp="2" ctrlrange="-40 40"/>

        <position name="r_r_pos" joint="r_r" kp="2" ctrlrange="-355 355"/>
        <position name="ud_r_pos" joint="ud_r" kp="2" ctrlrange="-40 40"/>

        <position name="r_ru_pos" joint="r_ru" kp="2" ctrlrange="0 355"/>
        <position name="r_rl_pos" joint="r_rl" kp="2" ctrlrange="0 355"/>

    </actuator>

    <keyframe>
        <!--         base link  x y z   w   x     y z     r_lm  ud_lm  r_l  ud_l     r_lu    r_ll  r_rm  ud_rm   r_r  ud_r  r_ru   r_rl     human x y    z-->
        <key name="init0" qpos="0 0 0.2 0.5 0.866 0 0     0     0     -1    0        2.2     2     0     0      -1    0     2.2     2        0 -1.4 1.2 0.707 0 -0.707 0"
            ctrl="0 0 -114 0 250.8 228 0 0 -114 0 250.8 228" /> <!--x with middle links tilted forward and side links tilted back-->
        <key name="init1" qpos="0 0 0.2 0.5 0.866 0 0     0     0      0    0        2.2     2     0     0       0    0     2.2     2        0 -1.4 1.2 0.707 0 -0.707 0"
            ctrl="0 0 0 0 250.8 228 0 0 0 0 250.8 228" /> <!--standing straight up-->
        <key name="init2" qpos="0 0 0.2 0.5 0.866 0 0    -1     0      1    0        1.2     2    -1     0       1    0     1.2     2        0 -1.4 1.2 0.707 0 -0.707 0"
            ctrl="-114 0 114 0 136.8 228 -114 0 114 0 136.8 228"/> <!--x with middle links tilted back and side links tilted forward-->
        <key name="init3" qpos="0 0 0.2 0.5 0.866 0 0    -1     0      0    0        2.6     2     0    0       -1    0     2.6     2        0 -1.4 1.2 0.707 0 -0.707 0"
            ctrl="-114 0 0 0 296.4 228 0 0 -114 0 296.4 228"/> <!--x with middle right link tilted forward and all other links tilted back-->
        <key name="init4" qpos="0 0 0.2 0.5 0.866 0 0     0     0     -1    0        2.6     2    -1    0        0    0     2.6     2        0 -1.4 1.2 0.707 0 -0.707 0"
            ctrl="0 0 -114 0 296.4 228 -114 0 0 0 296.4 228"/> <!--x with middle left link tilted forward and all other links tilted back-->
    </keyframe>

</mujoco>
