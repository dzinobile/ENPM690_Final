<mujoco>
    <compiler meshdir="meshes" />
    <compiler angle="degree"/>

    <option timestep="0.001" integrator="RK4" gravity="0 0 -9.81"/>

    <default>
        <joint limited="true" damping="30" armature="0.05" stiffness="0" actuatorfrcrange="-400 400"/>
        <!-- contype=0 conaffinity=0: structural geoms (torso, leg capsules) do not
         participate in any collision.  Feet override this to contype=1 so they
         collide with the floor (conaffinity=1) but not with each other. -->
        <geom condim="3" friction="1.2 0.005 0.0001" density="100" contype="0" conaffinity="0"/>
        <motor ctrllimited="true" ctrlrange="-1 1" gear="120"/>
    </default>

    <asset>
    <!--this scale makes it so that the robot is 1 meter in height, assuming mujoco base units are in meters-->
        <mesh name="base" file="base_link.STL" scale="0.002 0.002 0.002" />
        <mesh name="middle_left" file="left_middle_link.STL" scale="0.002 0.002 0.002" />
        <mesh name="left" file="left_link.STL" scale="0.002 0.002 0.002" />
        <mesh name="left_upper_arm" file="left_arm_upper_link.STL" scale="0.002 0.002 0.002" />
        <mesh name="left_lower_arm" file="left_arm_lower_link.STL" scale="0.002 0.002 0.002" />
        <mesh name="right" file="right_link.STL" scale="0.002 0.002 0.002" />
        <mesh name="right_upper_arm" file="right_arm_upper_link.STL" scale="0.002 0.002 0.002" />
        <mesh name="right_lower_arm" file="right_arm_lower_link.STL" scale="0.002 0.002 0.002" />
    </asset>

    <worldbody>
        <light name="sun" pos="0 0 6" dir="0 0 -1" diffuse="1 1 1" specular="0.3 0.3 0.3"/>
        <geom name="floor" type="plane" size="50 50 0.1" rgba="0.75 0.85 0.75 1" friction="1.0 0.005 0.0001"  />
        <!--WHOLE ROBOT NAME-->
        <body name="tars_robot" euler="90 0 0">
            <!--BASE-->
            <body name="base_link">
                <geom type="mesh" mesh="base" rgba="0.35 0.45 0.75 1"  />
                <!--LEFT CHAIN-->
                <!--LEFT BASE LINK-->
                <body>
                    <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                    <!--Rotation joint between base and left base links-->
                    <joint name="r_mm" type="hinge" axis="1 0 0" pos="0 1 0.15" range="-355 355" damping="100" />
                    <body name="left_base_link">
                        <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                        <!--Translation Joint between base and left base links-->
                        <joint name="ud_mm" type="slide" axis="0 1 0" range="-0.05 0.05" damping="10" />
                        <geom type="mesh" mesh="middle_left" rgba="0.55 0.65 0.45 1"  />
                        <!--LEFT LINK-->
                        <body>
                            <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                            <!--Rotation joint between left base and left links-->
                            <joint name="r_lm" type="hinge" axis="1 0 0" pos="0 1 0.15" range="-355 355" damping="100" />
                            <body name="left_link">
                                <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                                <!--Translation joint between left base and left links-->
                                <joint name="ud_lm" type="slide" axis="0 1 0" range="-0.05 0.05" damping="10" />
                                <geom type="mesh" mesh="left" rgba="0.5 0.5 0.5 1" />
                                <!--LEFT UPPER ARM-->
                                <body name="left_upper_arm">
                                    <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                                    <!--Joint between left link and left upper arm-->
                                    <joint name="r_lu" type="hinge" axis="1 0 0" pos="0 1 0.2" range="0 270" damping="100" />
                                    <geom type="mesh" mesh="left_upper_arm" rgba="0.5 0 0.5 1" />
                                    <!--LEFT LOWER ARM-->
                                    <body name="left_lower_arm">
                                        <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                                        <!--Joint between left upper arm and left lower arm-->
                                        <joint name="r_ll" type="hinge" axis="1 0 0" pos="0 2 0.15" range="0 355" damping="100" />
                                        <geom type="mesh" mesh="left_lower_arm" rgba="0 0.5 0.5 1" />
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
                <!--RIGHT CHAIN-->
                <!--RIGHT LINK-->
                <body>
                    <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                    <!--Rotation joint between base and right links-->
                    <joint name="r_rm" type="hinge" axis="1 0 0" pos="0 1 0.15" range="-355 355" damping="100" />
                    <body name="right_link">
                        <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                        <!--Translation joint between left base and left links-->
                        <joint name="ud_rm" type="slide" axis="0 1 0" range="-0.05 0.05" damping="10" />
                        <geom type="mesh" mesh="right" rgba="0.5 0.5 0.5 1" />
                        <!--RIGHT UPPER ARM-->
                        <body name="right_upper_arm">
                            <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                            <!--Joint between right link and right upper arm-->
                            <joint name="r_ru" type="hinge" axis="1 0 0" pos="0 1 0.2" range="0 270" damping="100" />
                            <geom type="mesh" mesh="right_upper_arm" rgba="0.5 0 0.5 1" />
                            <!--RIGHT LOWER ARM-->
                            <body name="right_lower_arm">
                                <inertial pos="0 0 0" mass="5" diaginertia="0.05 0.05 0.05"/>
                                <!--Joint between right upper arm and right lower arm-->
                                <joint name="r_rl" type="hinge" axis="1 0 0" pos="0 2 0.15" range="0 355" damping="100" />
                                <geom type="mesh" mesh="right_lower_arm" rgba="0 0.5 0.5 1" />
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position name="ud_mm_pos" joint="ud_mm" kp="5"  ctrlrange="-10 10"/>
        <position name="r_mm_pos" joint="r_mm" kp="5"  ctrlrange="-355 355"/>
        <position name="ud_lm_pos" joint="ud_lm" kp="5"  ctrlrange="-10 10"/>
        <position name="r_lm_pos" joint="r_lm" kp="5"  ctrlrange="-355 355"/>
        <position name="r_lu_pos" joint="r_lu" kp="5"  ctrlrange="0 355"/>
        <position name="r_ll_pos" joint="r_ll" kp="5"  ctrlrange="0 355"/>
        <position name="ud_rm_pos" joint="ud_rm" kp="5"  ctrlrange="-10 10"/>
        <position name="r_rm_pos" joint="r_rm" kp="5"  ctrlrange="-355 355"/>
        <position name="r_ru_pos" joint="r_ru" kp="5"  ctrlrange="0 355"/>
        <position name="r_rl_pos" joint="r_rl" kp="5"  ctrlrange="0 355"/>
    </actuator>

</mujoco>