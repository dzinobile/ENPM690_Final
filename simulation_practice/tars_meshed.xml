<mujoco>
    <compiler meshdir="meshes" />
    <compiler angle="degree"/>

    <option timestep="0.001" integrator="RK4" gravity="0 0 -9.81"/>

    <default>
        <joint limited="true" damping="30" armature="0.05" stiffness="0" actuatorfrcrange="-400 400"/>
        <!-- contype=0 conaffinity=0: structural geoms (torso, leg capsules) do not
         participate in any collision.  Feet override this to contype=1 so they
         collide with the floor (conaffinity=1) but not with each other. -->
        <geom condim="3" friction="1.2 0.005 0.0001" density="100"
          contype="0" conaffinity="0"/>
        <motor ctrllimited="true" ctrlrange="-1 1" gear="120"/>
    </default>

    <asset>
        <mesh name="base" file="base_link.STL" scale="0.01 0.01 0.01" />
        <mesh name="middle_left" file="left_middle_link.STL" scale="0.01 0.01 0.01" />
        <mesh name="left" file="left_link.STL" scale="0.01 0.01 0.01" />
        <mesh name="left_upper_arm" file="left_arm_upper_link.STL" scale="0.01 0.01 0.01" />
        <mesh name="left_lower_arm" file="left_arm_lower_link.STL" scale="0.01 0.01 0.01" />
        <mesh name="right" file="right_link.STL" scale="0.01 0.01 0.01" />
        <mesh name="right_upper_arm" file="right_arm_upper_link.STL" scale="0.01 0.01 0.01" />
        <mesh name="right_lower_arm" file="right_arm_lower_link.STL" scale="0.01 0.01 0.01" />
    </asset>

    <worldbody>
        <light name="sun" pos="0 0 6" dir="0 0 -1" diffuse="1 1 1" specular="0.3 0.3 0.3"/>
        <geom name="floor" type="plane" size="50 50 0.1" rgba="0.75 0.85 0.75 1" contype="1" conaffinity="1"/>

        <!--WHOLE ROBOT NAME-->
        <body name="tars_robot">
            <!--BASE-->
            <body name="base_link">
                <geom type="mesh" mesh="base" rgba="0.35 0.45 0.75 1"/>
                <!--LEFT CHAIN-->
                <body name="left_base_link">
                    <joint name="ud_mm" type="slide" axis="0 0 1" range="-0.05 0.05" damping="50" />
                    <joint name="r_mm" type="hinge" axis="1 0 0" pos="0 0 0" range="-355 355" damping="10" />
                    <geom type="mesh" mesh="middle_left" rgba="0.55 0.65 0.45 1" />
                    <body name="left_link">
                        <geom type="mesh" mesh="left" rgba="0.5 0.5 0.5 1" />
                        <body name="left_upper_arm">
                            <geom type="mesh" mesh="left_upper_arm" rgba="0.5 0 0.5 1" />
                            <body name="left_lower_arm">
                                <geom type="mesh" mesh="left_lower_arm" rgba="0 0.5 0.5 1" />
                            </body>
                        </body>
                    </body>
                </body>
                <!--RIGHT CHAIN-->
                <body name="right_link">
                    <geom type="mesh" mesh="right" rgba="0.5 0.5 0.5 1" />
                    <body name="right_upper_arm">
                        <geom type="mesh" mesh="right_upper_arm" rgba="0.5 0 0.5 1" />
                        <body name="right_lower_arm">
                            <geom type="mesh" mesh="right_lower_arm" rgba="0 0.5 0.5 1" />
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position name="ud_mm_pos" joint="ud_mm" kp="0.5"  ctrlrange="-50 50"/>
        <position name="r_mm_pos" joint="r_mm" kp="0.5"  ctrlrange="-355 355"/>
    </actuator>

</mujoco>